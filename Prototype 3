<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Campus Connect — SMVIT</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg: #0a0a0f;
  --surface: #12121a;
  --surface2: #1a1a26;
  --border: rgba(255,255,255,0.08);
  --accent: #6ee7b7;
  --accent2: #f59e0b;
  --accent3: #a78bfa;
  --text: #e8e8f0;
  --muted: #6b6b80;
  --danger: #f87171;
  --admin-accent: #f59e0b;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'DM Mono', monospace; background: var(--bg); color: var(--text); min-height: 100vh; overflow-x: hidden; }
body::before { content: ''; position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E"); pointer-events: none; z-index: 9999; opacity: 0.4; }

.screen { display: none; min-height: 100vh; }
.screen.active { display: flex; flex-direction: column; }

/* LOGIN */
#login-screen { align-items: center; justify-content: center; position: relative; background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(110,231,183,0.12) 0%, transparent 70%), radial-gradient(ellipse 60% 40% at 80% 80%, rgba(167,139,250,0.08) 0%, transparent 60%), var(--bg); }
.login-orb { position: absolute; border-radius: 50%; filter: blur(80px); pointer-events: none; }
.orb1 { width: 400px; height: 400px; background: rgba(110,231,183,0.08); top: -100px; left: -100px; animation: drift 12s ease-in-out infinite; }
.orb2 { width: 300px; height: 300px; background: rgba(167,139,250,0.08); bottom: -50px; right: -50px; animation: drift 10s ease-in-out infinite reverse; }
@keyframes drift { 0%,100% { transform: translate(0,0); } 50% { transform: translate(30px,20px); } }

.login-card { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 48px; width: 100%; max-width: 440px; position: relative; backdrop-filter: blur(20px); box-shadow: 0 40px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.05); animation: fadeUp 0.6s ease both; }
@keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }

.login-logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 28px; letter-spacing: -0.5px; margin-bottom: 6px; }
.login-logo span { color: var(--accent); }
.login-tagline { font-size: 12px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 40px; }

.google-btn { width: 100%; padding: 14px; border-radius: 12px; border: 1px solid var(--border); background: var(--surface2); color: var(--text); font-family: 'Syne', sans-serif; font-weight: 700; font-size: 15px; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 16px; }
.google-btn:hover { background: rgba(110,231,183,0.08); border-color: rgba(110,231,183,0.4); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
.google-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
.google-icon { width: 20px; height: 20px; flex-shrink: 0; }

.login-divider { display: flex; align-items: center; gap: 12px; margin: 20px 0; }
.login-divider::before, .login-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }
.login-divider span { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; }

.admin-login-btn { width: 100%; padding: 12px; border-radius: 12px; border: 1px solid rgba(245,158,11,0.3); background: rgba(245,158,11,0.06); color: var(--admin-accent); font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 10px; }
.admin-login-btn:hover { background: rgba(245,158,11,0.12); border-color: rgba(245,158,11,0.5); transform: translateY(-1px); }
.admin-login-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

.login-hint { font-size: 11px; color: var(--muted); text-align: center; margin-top: 20px; line-height: 1.6; }

/* LOADING SPINNER */
.spinner { width: 18px; height: 18px; border: 2px solid rgba(255,255,255,0.2); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.6s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

/* NAV */
.navbar { display: flex; align-items: center; justify-content: space-between; padding: 16px 32px; border-bottom: 1px solid var(--border); background: rgba(10,10,15,0.9); backdrop-filter: blur(20px); position: sticky; top: 0; z-index: 100; }
.nav-logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 20px; letter-spacing: -0.3px; }
.nav-logo span { color: var(--accent); }
.nav-logo.admin-mode span { color: var(--admin-accent); }
.nav-badge { font-size: 10px; padding: 3px 10px; border-radius: 999px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 500; }
.badge-student { background: rgba(110,231,183,0.15); color: var(--accent); border: 1px solid rgba(110,231,183,0.3); }
.badge-admin { background: rgba(245,158,11,0.15); color: var(--admin-accent); border: 1px solid rgba(245,158,11,0.3); }
.nav-right { display: flex; align-items: center; gap: 12px; }
.nav-user { font-size: 11px; color: var(--muted); max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.nav-avatar { width: 32px; height: 32px; border-radius: 50%; border: 2px solid var(--border); object-fit: cover; }
.btn-logout { background: none; border: 1px solid var(--border); border-radius: 8px; color: var(--muted); font-family: 'DM Mono', monospace; font-size: 12px; padding: 6px 14px; cursor: pointer; transition: all 0.2s; }
.btn-logout:hover { border-color: var(--danger); color: var(--danger); }

/* STUDENT */
#student-screen { background: var(--bg); }
.student-hero { padding: 48px 32px 36px; position: relative; overflow: hidden; }
.student-hero::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 60% 80% at 20% 50%, rgba(110,231,183,0.05) 0%, transparent 70%); pointer-events: none; }
.hero-greeting { font-size: 12px; color: var(--muted); letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 8px; }
.hero-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(28px, 4vw, 44px); line-height: 1.1; letter-spacing: -1px; margin-bottom: 8px; }
.hero-title em { font-family: 'Instrument Serif', serif; font-style: italic; color: var(--accent); }
.hero-sub { font-size: 13px; color: var(--muted); }

.filters-bar { padding: 0 32px 24px; display: flex; gap: 8px; flex-wrap: wrap; }
.filter-chip { padding: 7px 16px; border-radius: 999px; border: 1px solid var(--border); background: var(--surface); color: var(--muted); font-family: 'DM Mono', monospace; font-size: 12px; cursor: pointer; transition: all 0.2s; letter-spacing: 0.04em; }
.filter-chip:hover { border-color: rgba(110,231,183,0.4); color: var(--accent); }
.filter-chip.active { background: rgba(110,231,183,0.12); border-color: var(--accent); color: var(--accent); }

.events-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; padding: 0 32px 48px; }

.event-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 24px; transition: all 0.25s; position: relative; overflow: hidden; animation: cardIn 0.4s ease both; }
@keyframes cardIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
.event-card:hover { border-color: rgba(110,231,183,0.25); transform: translateY(-2px); box-shadow: 0 12px 32px rgba(0,0,0,0.4); }
.event-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; border-radius: 16px 16px 0 0; opacity: 0; transition: opacity 0.3s; }
.event-card:hover::before { opacity: 1; }
.card-hackathon::before { background: linear-gradient(90deg, var(--accent), #34d399); }
.card-workshop::before { background: linear-gradient(90deg, var(--accent3), #8b5cf6); }
.card-seminar::before { background: linear-gradient(90deg, var(--accent2), #f97316); }
.card-cultural::before { background: linear-gradient(90deg, #ec4899, #f43f5e); }

.card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
.card-category { font-size: 10px; padding: 3px 10px; border-radius: 999px; letter-spacing: 0.1em; text-transform: uppercase; }
.cat-hackathon { background: rgba(110,231,183,0.12); color: var(--accent); }
.cat-workshop  { background: rgba(167,139,250,0.12); color: var(--accent3); }
.cat-seminar   { background: rgba(245,158,11,0.12); color: var(--accent2); }
.cat-cultural  { background: rgba(236,72,153,0.12); color: #f472b6; }
.card-capacity { font-size: 11px; color: var(--muted); }
.card-capacity span { color: var(--text); font-weight: 500; }
.card-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 18px; margin-bottom: 6px; letter-spacing: -0.3px; line-height: 1.3; }
.card-club { font-size: 12px; color: var(--muted); margin-bottom: 4px; }
.card-date { font-size: 12px; color: var(--muted); margin-bottom: 16px; }
.card-date span { color: var(--text); }
.capacity-bar { height: 3px; background: var(--border); border-radius: 999px; margin-bottom: 16px; overflow: hidden; }
.capacity-fill { height: 100%; border-radius: 999px; transition: width 0.5s ease; }
.fill-hackathon { background: var(--accent); }
.fill-workshop  { background: var(--accent3); }
.fill-seminar   { background: var(--accent2); }
.fill-cultural  { background: #f472b6; }

.btn-rsvp { width: 100%; padding: 11px; border-radius: 10px; border: 1px solid var(--border); background: var(--surface2); color: var(--text); font-family: 'Syne', sans-serif; font-weight: 600; font-size: 13px; cursor: pointer; transition: all 0.25s; letter-spacing: 0.02em; }
.btn-rsvp:hover:not(.registered):not(.full) { background: rgba(110,231,183,0.12); border-color: var(--accent); color: var(--accent); }
.btn-rsvp.registered { background: rgba(110,231,183,0.15); border-color: var(--accent); color: var(--accent); cursor: default; }
.btn-rsvp.full { opacity: 0.5; cursor: not-allowed; }

/* ADMIN */
#admin-screen { background: var(--bg); }
.admin-hero { padding: 48px 32px 36px; background: radial-gradient(ellipse 50% 70% at 10% 50%, rgba(245,158,11,0.06) 0%, transparent 70%); }
.admin-hero .hero-title em { color: var(--admin-accent); }

.admin-stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px; padding: 0 32px 32px; }
.stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 20px; transition: border-color 0.2s; }
.stat-card:hover { border-color: rgba(245,158,11,0.3); }
.stat-label { font-size: 10px; color: var(--muted); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 10px; }
.stat-value { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 32px; color: var(--admin-accent); letter-spacing: -1px; }
.stat-sub { font-size: 11px; color: var(--muted); margin-top: 4px; }

.admin-section-header { display: flex; align-items: center; justify-content: space-between; padding: 0 32px 20px; }
.section-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 20px; }
.btn-new-event { background: var(--admin-accent); color: #0a0a0f; border: none; border-radius: 10px; padding: 10px 20px; font-family: 'Syne', sans-serif; font-weight: 700; font-size: 13px; cursor: pointer; transition: all 0.2s; }
.btn-new-event:hover { background: #fcd34d; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(245,158,11,0.3); }

.admin-events-list { padding: 0 32px 48px; display: flex; flex-direction: column; gap: 12px; }
.admin-event-row { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 20px 24px; display: flex; align-items: center; gap: 20px; transition: all 0.2s; animation: cardIn 0.3s ease both; }
.admin-event-row:hover { border-color: rgba(245,158,11,0.3); transform: translateX(4px); }
.admin-event-main { flex: 1; }
.admin-event-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 16px; margin-bottom: 4px; }
.admin-event-meta { font-size: 12px; color: var(--muted); }
.admin-event-meta span { color: var(--text); }
.rsvp-counter { text-align: center; min-width: 80px; }
.rsvp-num { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 26px; color: var(--admin-accent); }
.rsvp-label { font-size: 10px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; }
.admin-capacity-bar { width: 100px; height: 4px; background: var(--border); border-radius: 999px; overflow: hidden; margin-top: 8px; }
.admin-capacity-fill { height: 100%; background: var(--admin-accent); border-radius: 999px; transition: width 0.5s; }
.btn-delete { background: none; border: 1px solid var(--border); border-radius: 8px; color: var(--muted); padding: 6px 12px; font-family: 'DM Mono', monospace; font-size: 11px; cursor: pointer; transition: all 0.2s; }
.btn-delete:hover { border-color: var(--danger); color: var(--danger); }

/* MODAL */
.modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(8px); z-index: 1000; align-items: center; justify-content: center; padding: 20px; }
.modal-overlay.open { display: flex; }
.modal { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 40px; width: 100%; max-width: 480px; box-shadow: 0 40px 80px rgba(0,0,0,0.6); animation: modalIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
@keyframes modalIn { from { opacity: 0; transform: scale(0.92) translateY(20px); } to { opacity: 1; transform: scale(1) translateY(0); } }
.modal-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 22px; margin-bottom: 4px; }
.modal-sub { font-size: 12px; color: var(--muted); margin-bottom: 28px; }
.form-group { margin-bottom: 20px; }
.form-label { display: block; font-size: 11px; color: var(--muted); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 8px; }
.form-input { width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: 10px; padding: 12px 16px; font-family: 'DM Mono', monospace; font-size: 14px; color: var(--text); outline: none; transition: border-color 0.2s, box-shadow 0.2s; }
.form-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(110,231,183,0.12); }
select.form-input { cursor: pointer; }
select.form-input option { background: #1a1a26; }
.modal-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.modal-actions { display: flex; gap: 12px; margin-top: 28px; }
.btn-cancel { flex: 1; padding: 12px; border-radius: 10px; border: 1px solid var(--border); background: none; color: var(--muted); font-family: 'DM Mono', monospace; font-size: 13px; cursor: pointer; transition: all 0.2s; }
.btn-cancel:hover { border-color: var(--text); color: var(--text); }
.btn-submit { flex: 2; padding: 12px; border-radius: 10px; border: none; background: var(--admin-accent); color: #0a0a0f; font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px; cursor: pointer; transition: all 0.2s; }
.btn-submit:hover { background: #fcd34d; }
.btn-submit:disabled { opacity: 0.5; cursor: not-allowed; }

/* TOAST */
.toast { position: fixed; bottom: 32px; left: 50%; transform: translateX(-50%) translateY(80px); background: var(--surface2); border: 1px solid var(--border); border-radius: 12px; padding: 14px 24px; font-size: 13px; display: flex; align-items: center; gap: 10px; z-index: 9000; transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s; opacity: 0; white-space: nowrap; box-shadow: 0 20px 40px rgba(0,0,0,0.5); }
.toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
.toast-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
.toast.admin-toast .toast-dot { background: var(--admin-accent); }
.toast.error-toast .toast-dot { background: var(--danger); }

.empty-state { text-align: center; padding: 80px 32px; color: var(--muted); grid-column: 1/-1; }
.empty-state .icon { font-size: 48px; margin-bottom: 16px; opacity: 0.4; }
.empty-state p { font-size: 14px; }

.loading-state { text-align: center; padding: 80px 32px; color: var(--muted); grid-column: 1/-1; display: flex; flex-direction: column; align-items: center; gap: 16px; }
.loading-state .big-spinner { width: 32px; height: 32px; border: 3px solid rgba(110,231,183,0.2); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; }

/* RSVP CONFIRM MODAL */
.rsvp-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.75); backdrop-filter: blur(10px); z-index: 1100; align-items: center; justify-content: center; padding: 20px; }
.rsvp-overlay.open { display: flex; }
.rsvp-modal { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; width: 100%; max-width: 440px; overflow: hidden; box-shadow: 0 40px 80px rgba(0,0,0,0.6); animation: modalIn 0.3s cubic-bezier(0.34,1.56,0.64,1); }

/* Step indicator */
.rsvp-steps { display: flex; border-bottom: 1px solid var(--border); }
.rsvp-step-tab { flex: 1; padding: 14px; text-align: center; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); transition: all 0.3s; position: relative; }
.rsvp-step-tab.active { color: var(--accent); }
.rsvp-step-tab.active::after { content: ''; position: absolute; bottom: 0; left: 20%; right: 20%; height: 2px; background: var(--accent); border-radius: 2px 2px 0 0; }
.rsvp-step-tab.done { color: var(--accent); opacity: 0.5; }
.rsvp-step-num { display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; border-radius: 50%; border: 1px solid currentColor; font-size: 10px; margin-right: 6px; }
.rsvp-step-tab.done .rsvp-step-num { background: var(--accent); color: #0a0a0f; border-color: var(--accent); }

.rsvp-body { padding: 32px; }

/* Step 1 — Event preview */
.rsvp-event-banner { border-radius: 12px; padding: 20px; margin-bottom: 24px; border: 1px solid; }
.rsvp-event-banner.cat-hackathon { background: rgba(110,231,183,0.06); border-color: rgba(110,231,183,0.2); }
.rsvp-event-banner.cat-workshop  { background: rgba(167,139,250,0.06); border-color: rgba(167,139,250,0.2); }
.rsvp-event-banner.cat-seminar   { background: rgba(245,158,11,0.06);  border-color: rgba(245,158,11,0.2);  }
.rsvp-event-banner.cat-cultural  { background: rgba(236,72,153,0.06);  border-color: rgba(236,72,153,0.2);  }
.rsvp-banner-cat { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 8px; opacity: 0.8; }
.rsvp-banner-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 20px; letter-spacing: -0.3px; margin-bottom: 12px; }
.rsvp-banner-meta { display: flex; flex-direction: column; gap: 5px; }
.rsvp-meta-row { font-size: 12px; color: var(--muted); display: flex; gap: 8px; }
.rsvp-meta-row span { color: var(--text); }

.rsvp-section-label { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 10px; }
.rsvp-user-info { display: flex; align-items: center; gap: 12px; background: var(--surface2); border: 1px solid var(--border); border-radius: 12px; padding: 14px 16px; }
.rsvp-user-avatar { width: 36px; height: 36px; border-radius: 50%; border: 2px solid var(--border); object-fit: cover; flex-shrink: 0; }
.rsvp-user-avatar-placeholder { width: 36px; height: 36px; border-radius: 50%; background: rgba(110,231,183,0.15); border: 2px solid rgba(110,231,183,0.3); display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }
.rsvp-user-details { flex: 1; min-width: 0; }
.rsvp-user-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.rsvp-user-email { font-size: 11px; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* Step 2 — Confirm */
.rsvp-confirm-icon { width: 64px; height: 64px; border-radius: 50%; background: rgba(110,231,183,0.12); border: 2px solid rgba(110,231,183,0.3); display: flex; align-items: center; justify-content: center; font-size: 28px; margin: 0 auto 20px; }
.rsvp-confirm-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 20px; text-align: center; margin-bottom: 8px; }
.rsvp-confirm-sub { font-size: 13px; color: var(--muted); text-align: center; margin-bottom: 24px; line-height: 1.6; }
.rsvp-confirm-summary { background: var(--surface2); border: 1px solid var(--border); border-radius: 12px; padding: 16px 20px; margin-bottom: 24px; }
.rsvp-summary-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid var(--border); font-size: 12px; }
.rsvp-summary-row:last-child { border-bottom: none; }
.rsvp-summary-key { color: var(--muted); }
.rsvp-summary-val { color: var(--text); font-weight: 500; text-align: right; max-width: 60%; }

.rsvp-actions { display: flex; gap: 12px; }
.rsvp-btn-back { flex: 1; padding: 12px; border-radius: 10px; border: 1px solid var(--border); background: none; color: var(--muted); font-family: 'DM Mono', monospace; font-size: 13px; cursor: pointer; transition: all 0.2s; }
.rsvp-btn-back:hover { border-color: var(--text); color: var(--text); }
.rsvp-btn-confirm { flex: 2; padding: 12px; border-radius: 10px; border: none; background: var(--accent); color: #0a0a0f; font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; }
.rsvp-btn-confirm:hover { background: #a7f3d0; }
.rsvp-btn-confirm:disabled { opacity: 0.5; cursor: not-allowed; }
.rsvp-btn-cancel-top { position: absolute; top: 16px; right: 16px; background: none; border: none; color: var(--muted); font-size: 18px; cursor: pointer; padding: 4px 8px; border-radius: 6px; transition: color 0.2s; }
.rsvp-btn-cancel-top:hover { color: var(--text); }
.rsvp-modal-wrap { position: relative; }

/* Step transition */
.rsvp-step-panel { display: none; }
.rsvp-step-panel.active { display: block; animation: fadeUp 0.25s ease both; }
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen" class="screen active">
  <div class="login-orb orb1"></div>
  <div class="login-orb orb2"></div>
  <div class="login-card">
    <div class="login-logo">Campus <span>Connect</span></div>
    <div class="login-tagline">SMVIT Event Platform</div>

    <button class="google-btn" id="google-login-btn" onclick="loginWithGoogle()">
      <svg class="google-icon" viewBox="0 0 24 24">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
