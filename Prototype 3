<!-- FIREBASE -->
<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getAuth, signInWithPopup, GoogleAuthProvider, signOut, onAuthStateChanged }
  from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";
import { getFirestore, collection, getDocs, addDoc, updateDoc, deleteDoc,
         doc, onSnapshot, query, where, orderBy, serverTimestamp, getDoc, setDoc, increment }
  from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

const firebaseConfig = {
  apiKey: "AIzaSyCEPl8n-YcdqjifIvvkCdV9OsArABB4RRw",
  authDomain: "smvit-eventhub.firebaseapp.com",
  projectId: "smvit-eventhub",
  storageBucket: "smvit-eventhub.firebasestorage.app",
  messagingSenderId: "65216660971",
  appId: "1:65216660971:web:ef84458fa7fdbacc8805ae",
  measurementId: "G-XZZRWHB62V"
};

const app  = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db   = getFirestore(app);

// ─── ADMIN EMAILS ────────────────────────────────────────────────
// Add your admin Gmail addresses here
const ADMIN_EMAILS = [
  "eventhubsmvit@gmail.com",
  "adityakumaryadav2311@gmail.com",
  "adityakharga08@gmail.com",
  // add more admin emails here
];

// ─── STATE ───────────────────────────────────────────────────────
let currentUser   = null;
let currentRole   = null;
let currentFilter = 'all';
let allEvents     = [];
let myRsvps       = new Set();
let unsubEvents   = null;

const categories = ['all','hackathon','workshop','seminar','cultural'];

// ─── AUTH STATE ──────────────────────────────────────────────────
onAuthStateChanged(auth, async (user) => {
  if (user) {
    currentUser = user;
    const role = ADMIN_EMAILS.includes(user.email) ? 'admin' : 'student';
    currentRole = role;
    if (role === 'student') {
      await loadMyRsvps();
      showScreen('student-screen');
      renderStudentNav();
      subscribeToEvents();
    } else {
      showScreen('admin-screen');
      renderAdminNav();
      subscribeToAdminEvents();
    }
  } else {
    currentUser = null;
    currentRole = null;
    if (unsubEvents) { unsubEvents(); unsubEvents = null; }
    showScreen('login-screen');
    enableLoginBtns();
  }
});

// ─── LOGIN ───────────────────────────────────────────────────────
window.loginWithGoogle = async function() {
  disableLoginBtns();
  try {
    const provider = new GoogleAuthProvider();
    await signInWithPopup(auth, provider);
    // onAuthStateChanged handles the rest
  } catch(e) {
    enableLoginBtns();
    if (e.code !== 'auth/popup-closed-by-user') {
      showToast('Login failed: ' + e.message, 'error');
    }
  }
};

window.loginAsAdmin = async function() {
  disableLoginBtns();
  try {
    const provider = new GoogleAuthProvider();
    const result = await signInWithPopup(auth, provider);
    if (!ADMIN_EMAILS.includes(result.user.email)) {
      await signOut(auth);
      enableLoginBtns();
      showToast('This account is not registered as an admin.', 'error');
    }
  } catch(e) {
    enableLoginBtns();
    if (e.code !== 'auth/popup-closed-by-user') {
      showToast('Login failed: ' + e.message, 'error');
    }
  }
};

window.logout = async function() {
  if (unsubEvents) { unsubEvents(); unsubEvents = null; }
  await signOut(auth);
};

function disableLoginBtns() {
  const gb = document.getElementById('google-login-btn');
  const ab = document.getElementById('admin-login-btn');
  gb.disabled = true;
  ab.disabled = true;
  gb.innerHTML = `<div class="spinner"></div> Signing in...`;
}
function enableLoginBtns() {
  const gb = document.getElementById('google-login-btn');
  const ab = document.getElementById('admin-login-btn');
  gb.disabled = false;
  ab.disabled = false;
  gb.innerHTML = `<svg class="google-icon" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg> Continue with Google`;
}

// ─── NAV ─────────────────────────────────────────────────────────
function renderStudentNav() {
  document.getElementById('student-user-label').textContent = currentUser.displayName || currentUser.email;
  const av = document.getElementById('student-avatar');
  if (currentUser.photoURL) { av.src = currentUser.photoURL; av.style.display = 'block'; }
}
function renderAdminNav() {
  document.getElementById('admin-user-label').textContent = currentUser.displayName || currentUser.email;
  const av = document.getElementById('admin-avatar');
  if (currentUser.photoURL) { av.src = currentUser.photoURL; av.style.display = 'block'; }
}

// ─── STUDENT: LOAD RSVPs ─────────────────────────────────────────
async function loadMyRsvps() {
  myRsvps.clear();
  const snap = await getDocs(collection(db, 'users', currentUser.uid, 'rsvps'));
  snap.forEach(d => myRsvps.add(d.id));
}

// ─── STUDENT: SUBSCRIBE TO EVENTS ────────────────────────────────
function subscribeToEvents() {
  const grid = document.getElementById('events-grid');
  grid.innerHTML = `<div class="loading-state"><div class="big-spinner"></div><p>Loading events...</p></div>`;
  const q = query(collection(db, 'events'), orderBy('createdAt', 'desc'));
  unsubEvents = onSnapshot(q, (snap) => {
    allEvents = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    renderFilters();
    renderCards();
  }, (err) => {
    showToast('Failed to load events', 'error');
  });
}

// ─── STUDENT: RENDER ─────────────────────────────────────────────
function renderFilters() {
  const bar = document.getElementById('filters-bar');
  bar.innerHTML = categories.map(c =>
    `<button class="filter-chip ${currentFilter===c?'active':''}" onclick="window.setFilter('${c}')">
      ${c==='all' ? '✦ All Events' : cap(c)+'s'}
    </button>`
  ).join('');
}

window.setFilter = function(f) {
  currentFilter = f;
  renderFilters();
  renderCards();
};

function renderCards() {
  const grid = document.getElementById('events-grid');
  const filtered = currentFilter === 'all' ? allEvents : allEvents.filter(e => e.category === currentFilter);
  document.getElementById('student-event-count').textContent =
    `${filtered.length} event${filtered.length!==1?'s':''} available`;

  if (!filtered.length) {
    grid.innerHTML = `<div class="empty-state"><div class="icon">🎯</div><p>No ${currentFilter === 'all' ? '' : currentFilter} events right now.</p></div>`;
    return;
  }
  grid.innerHTML = filtered.map((e,i) => {
    const rsvps = e.rsvps || 0;
    const cap   = e.capacity || 1;
    const pct   = Math.min(100, Math.round(rsvps / cap * 100));
    const full  = rsvps >= cap;
    const reg   = myRsvps.has(e.id);
    return `
    <div class="event-card card-${e.category}" style="animation-delay:${i*0.05}s">
      <div class="card-top">
        <span class="card-category cat-${e.category}">${capWord(e.category)}</span>
        <span class="card-capacity"><span>${Math.max(0, cap - rsvps)}</span> spots left</span>
      </div>
      <div class="card-title">${e.title}</div>
      <div class="card-club">${e.club || ''}</div>
      <div class="card-date">📅 <span>${fmtDate(e.date)}</span> · ${fmtTime(e.time)} · ${e.venue}</div>
      <div class="capacity-bar"><div class="capacity-fill fill-${e.category}" style="width:${pct}%"></div></div>
      <button class="btn-rsvp ${reg?'registered':full?'full':''}"
        onclick="${reg||full ? '' : `window.doRsvp('${e.id}')`}">
        ${reg ? '✓ Registered' : full ? 'Event Full' : 'RSVP Now'}
      </button>
    </div>`;
  }).join('');
}

// ─── STUDENT: RSVP (TWO-STEP) ────────────────────────────────────
let pendingRsvpId = null;

window.doRsvp = function(eventId) {
  if (!currentUser) return;
  const ev = allEvents.find(e => e.id === eventId);
  if (!ev || myRsvps.has(eventId) || (ev.rsvps || 0) >= (ev.capacity || 0)) return;
  pendingRsvpId = eventId;
  openRsvpModal(ev);
};

function openRsvpModal(ev) {
  // Build event banner
  const banner = document.getElementById('rsvp-banner');
  banner.className = `rsvp-event-banner cat-${ev.category}`;
  banner.innerHTML = `
    <div class="rsvp-banner-cat">${capWord(ev.category)}</div>
    <div class="rsvp-banner-title">${ev.title}</div>
    <div class="rsvp-banner-meta">
      <div class="rsvp-meta-row">📅 <span>${fmtDate(ev.date)} · ${fmtTime(ev.time)}</span></div>
      <div class="rsvp-meta-row">📍 <span>${ev.venue}</span></div>
      <div class="rsvp-meta-row">👥 <span>${Math.max(0,(ev.capacity||0)-(ev.rsvps||0))} spots remaining</span></div>
    </div>`;

  // User info
  document.getElementById('rsvp-user-name').textContent = currentUser.displayName || 'Student';
  document.getElementById('rsvp-user-email').textContent = currentUser.email;
  const avatarWrap = document.getElementById('rsvp-avatar-wrap');
  if (currentUser.photoURL) {
    avatarWrap.innerHTML = `<img class="rsvp-user-avatar" src="${currentUser.photoURL}" alt=""/>`;
  } else {
    avatarWrap.innerHTML = `<div class="rsvp-user-avatar-placeholder">👤</div>`;
  }

  // Build step-2 summary
  document.getElementById('rsvp-summary').innerHTML = `
    <div class="rsvp-summary-row"><span class="rsvp-summary-key">Event</span><span class="rsvp-summary-val">${ev.title}</span></div>
    <div class="rsvp-summary-row"><span class="rsvp-summary-key">Date</span><span class="rsvp-summary-val">${fmtDate(ev.date)}, ${fmtTime(ev.time)}</span></div>
    <div class="rsvp-summary-row"><span class="rsvp-summary-key">Venue</span><span class="rsvp-summary-val">${ev.venue}</span></div>
    <div class="rsvp-summary-row"><span class="rsvp-summary-key">Name</span><span class="rsvp-summary-val">${currentUser.displayName || '—'}</span></div>
    <div class="rsvp-summary-row"><span class="rsvp-summary-key">Email</span><span class="rsvp-summary-val">${currentUser.email}</span></div>`;

  rsvpGoStep1();
  document.getElementById('rsvp-overlay').classList.add('open');
}

window.closeRsvpModal = function() {
  document.getElementById('rsvp-overlay').classList.remove('open');
  pendingRsvpId = null;
};

function rsvpGoStep1() {
  document.getElementById('rsvp-panel-1').classList.add('active');
  document.getElementById('rsvp-panel-2').classList.remove('active');
  document.getElementById('rsvp-tab-1').classList.add('active');
  document.getElementById('rsvp-tab-1').classList.remove('done');
  document.getElementById('rsvp-tab-2').classList.remove('active');
}

window.rsvpGoStep2 = function() {
  document.getElementById('rsvp-panel-1').classList.remove('active');
  document.getElementById('rsvp-panel-2').classList.add('active');
  document.getElementById('rsvp-tab-1').classList.remove('active');
  document.getElementById('rsvp-tab-1').classList.add('done');
  document.getElementById('rsvp-tab-2').classList.add('active');
};

window.rsvpGoStep1 = rsvpGoStep1;

window.confirmRsvp = async function() {
  if (!pendingRsvpId || !currentUser) return;
  const eventId = pendingRsvpId;
  const ev = allEvents.find(e => e.id === eventId);
  if (!ev) return;

  const btn = document.getElementById('rsvp-confirm-btn');
  const label = document.getElementById('rsvp-btn-label');
  btn.disabled = true;
  label.innerHTML = `<div class="spinner" style="border-top-color:#0a0a0f;border-color:rgba(0,0,0,0.2);border-top-color:#0a0a0f"></div>`;

  myRsvps.add(eventId);
  renderCards(); // optimistic

  try {
    await setDoc(doc(db, 'users', currentUser.uid, 'rsvps', eventId), {
      eventId,
      eventTitle: ev.title,
      rsvpedAt: serverTimestamp()
    });
    await updateDoc(doc(db, 'events', eventId), { rsvps: increment(1) });
    closeRsvpModal();
    showToast(`✓ Registered for "${ev.title}"`, 'student');
  } catch(e) {
    myRsvps.delete(eventId);
    renderCards();
    closeRsvpModal();
    showToast('RSVP failed. Try again.', 'error');
  } finally {
    btn.disabled = false;
    label.textContent = 'Confirm RSVP';
  }
};

// Close on backdrop click
document.getElementById('rsvp-overlay').addEventListener('click', function(e) {
  if (e.target === this) window.closeRsvpModal();
});

// ─── ADMIN: SUBSCRIBE ────────────────────────────────────────────
function subscribeToAdminEvents() {
  const adminClub = currentUser.displayName || currentUser.email;
  const list = document.getElementById('admin-events-list');
  list.innerHTML = `<div class="loading-state"><div class="big-spinner"></div><p>Loading your events...</p></div>`;

  const q = query(collection(db, 'events'),
    where('adminUid', '==', currentUser.uid),
    orderBy('createdAt', 'desc'));

  unsubEvents = onSnapshot(q, (snap) => {
    allEvents = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    renderAdminStats();
    renderAdminList();
  });
}

function renderAdminStats() {
  const totalRsvps = allEvents.reduce((a,e) => a + (e.rsvps||0), 0);
  const totalCap   = allEvents.reduce((a,e) => a + (e.capacity||0), 0);
  const openSpots  = allEvents.reduce((a,e) => a + Math.max(0,(e.capacity||0)-(e.rsvps||0)), 0);
  const fillRate   = totalCap ? Math.round(totalRsvps/totalCap*100) : 0;
  document.getElementById('stat-total').textContent = allEvents.length;
  document.getElementById('stat-rsvps').textContent = totalRsvps;
  document.getElementById('stat-fill').textContent  = fillRate+'%';
  document.getElementById('stat-spots').textContent = openSpots;
}

function renderAdminList() {
  const list = document.getElementById('admin-events-list');
  if (!allEvents.length) {
    list.innerHTML = `<div style="text-align:center;padding:60px;color:var(--muted);font-size:13px">No events yet. Post one to get started.</div>`;
    return;
  }
  list.innerHTML = allEvents.map((e,i) => {
    const pct = Math.min(100, Math.round((e.rsvps||0)/(e.capacity||1)*100));
    return `
    <div class="admin-event-row" style="animation-delay:${i*0.05}s">
      <div class="admin-event-main">
        <div class="admin-event-title">${e.title}</div>
        <div class="admin-event-meta">${capWord(e.category)} · ${fmtDate(e.date)} · <span>${e.venue}</span></div>
        <div class="admin-capacity-bar" style="margin-top:10px">
          <div class="admin-capacity-fill" style="width:${pct}%"></div>
        </div>
      </div>
      <div class="rsvp-counter">
        <div class="rsvp-num">${e.rsvps||0}</div>
        <div class="rsvp-label">RSVPs</div>
        <div style="font-size:11px;color:var(--muted);margin-top:2px">of ${e.capacity}</div>
      </div>
      <button class="btn-delete" onclick="window.deleteEvent('${e.id}')">✕ Remove</button>
    </div>`;
  }).join('');
}

window.deleteEvent = async function(eventId) {
  try {
    await deleteDoc(doc(db, 'events', eventId));
    showToast('Event removed', 'admin');
  } catch(e) {
    showToast('Failed to delete event', 'error');
  }
};

// ─── MODAL ───────────────────────────────────────────────────────
window.openModal = function() {
  const d = new Date(); d.setDate(d.getDate()+1);
  document.getElementById('m-date').value = d.toISOString().split('T')[0];
  document.getElementById('m-time').value = '10:00';
  document.getElementById('m-title').value = '';
  document.getElementById('m-capacity').value = '';
  document.getElementById('m-venue').value = '';
  document.getElementById('modal-overlay').classList.add('open');
};
window.closeModal = function() {
  document.getElementById('modal-overlay').classList.remove('open');
};

window.submitEvent = async function() {
  const title    = document.getElementById('m-title').value.trim();
  const category = document.getElementById('m-category').value;
  const capacity = parseInt(document.getElementById('m-capacity').value);
  const date     = document.getElementById('m-date').value;
  const time     = document.getElementById('m-time').value;
  const venue    = document.getElementById('m-venue').value.trim();

  if (!title || !capacity || !date || !venue) { showToast('Please fill all fields', 'error'); return; }
  if (isNaN(capacity) || capacity < 5) { showToast('Capacity must be at least 5', 'error'); return; }

  const btn = document.getElementById('submit-btn');
  btn.disabled = true;
  btn.textContent = 'Publishing...';

  try {
    await addDoc(collection(db, 'events'), {
      title, category, capacity,
      date, time, venue,
      rsvps: 0,
      club: currentUser.displayName || currentUser.email,
      adminUid: currentUser.uid,
      createdAt: serverTimestamp()
    });
    closeModal();
    showToast(`"${title}" is now live!`, 'admin');
  } catch(e) {
    showToast('Failed to publish. Try again.', 'error');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Publish Event →';
  }
};

document.getElementById('modal-overlay').addEventListener('click', function(e) {
  if (e.target === this) window.closeModal();
});

// ─── HELPERS ─────────────────────────────────────────────────────
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

let toastTimer;
function showToast(msg, type) {
  const t = document.getElementById('toast');
  t.className = 'toast' + (type==='admin'?' admin-toast':type==='error'?' error-toast':'');
  document.getElementById('toast-msg').textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 3500);
}

function cap(s) { return s.charAt(0).toUpperCase() + s.slice(1); }
function capWord(s) { return s ? s.charAt(0).toUpperCase() + s.slice(1) : ''; }
function fmtDate(d) {
  if (!d) return '';
  const dt = new Date(d + 'T00:00:00');
  return dt.toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' });
}
function fmtTime(t) {
  if (!t) return '';
  const [h,m] = t.split(':').map(Number);
  return `${h%12||12}:${String(m).padStart(2,'0')} ${h>=12?'PM':'AM'}`;
}
</script>
</body>
